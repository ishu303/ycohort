{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "postbuild": "react-snap",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "reactSnap": {
    "source": "dist",
    "include": [
      "/",
      "/jee-study-partner",
      "/neet-study-buddy",
      "/upsc-peer-group",
      "/cat-mba-study-group",
      "/nda-prep-buddy",
      "/study-buddy-delhi",
      "/study-buddy-kota",
      "/study-buddy-hyderabad",
      "/study-buddy-bengaluru",
      "/study-buddy-mumbai",
      "/study-buddy-pune",
      "/study-buddy-lucknow",
      "/study-buddy-patna",
      "/blog",
      "/blog/what-is-a-study-twin",
      "/blog/how-to-find-jee-study-partner",
      "/blog/why-solo-neet-prep-fails",
      "/blog/active-recall-vs-passive-video",
      "/blog/kota-paradox-isolation",
      "/blog/upsc-answer-writing-peer-evaluation",
      "/blog/voice-rooms-vs-telegram-cat",
      "/blog/drop-year-survival-guide"
    ],
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "skipThirdPartyRequests": true,
    "inlineCss": false,
    "removeBlobs": true,
    "fixWebpackChunksIssue": false,
    "crawl": false
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.1.0",
    "vite": "^6.2.3",
    "express": "^4.21.2",
    "dotenv": "^17.2.3",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "react-snap": "^1.23.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "@types/express": "^4.17.21"
  }
}
